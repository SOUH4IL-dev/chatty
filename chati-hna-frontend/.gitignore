```gitignore
# dependencies
node_modules/

# next.js
.next/
out/

# production
build/
dist/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# macOS
.DS_Store

# windows
Thumbs.db

# vscode
.vscode/

# idea
.idea/

# coverage
coverage/

# cache
.cache/
.parcel-cache/

# turbo
.turbo/

# vercel
.vercel/

# typescript
*.tsbuildinfo

# lock files (optional — remove if you want them tracked)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# temporary files
tmp/
temp/

# firebase
.firebase/

# uploads
uploads/

# sqlite
*.sqlite
*.db
```
